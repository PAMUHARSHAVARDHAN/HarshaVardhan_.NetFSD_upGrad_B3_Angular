@using WebApplication1.Models
@model List<Product>
    <h1> Product List</h1>
<a class="btn btn-primary" asp-action="Create">Create New</a>

    <Table class="table table-bordered">
        <Thead>
            <tr>
                <th>Id </th>
                <th>Name </th>
                <th>Category </th>
                <th>Price </th>
                <th></th>
            </tr>
        </Thead>
        <tbody>
            @foreach (Product p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Category</td>
                    <td>@p.Price</td>
                    <td>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id">Details</a> |

                    <a asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id">Edit</a> |

                    <a asp-controller="Product" asp-action="Delete" asp-route-id="@p.Id">Delete</a>

                    </td>
                </tr>

            }
        </tbody>
    </Table>
